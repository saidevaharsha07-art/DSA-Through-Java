{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "compile",
			"type": "shell",
			"command": "javac",
			"args": [
				"${file}"
			],
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"presentation": {
				"reveal": "never"
			}
		},
		{
			"label": "compile and run",
			"type": "shell",
			"command": "cmd.exe",
			"args": [
				"/c",
				"javac \"${file}\" && java \"${fileBasenameNoExtension}\" < input.txt > output.txt"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "never",
				"echo": false,
				"focus": false,
				"panel": "dedicated"
			}
		}
	]
}